---
import content from "../../content.json";
const m = content.media;
const cta = m.cta.replace(/[«»]/g, "").trim();
---

<section id="Блог" class="px-4 py-16 md:px-6 md:py-24">
  <div class="mx-auto max-w-[var(--spacing-container)]">
    <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <div>
        <span class="text-sm tracking-wide text-n80 uppercase">{m.label}</span>
        <h2 class="mt-4 text-[24px] leading-[30px] font-medium md:text-h2">{m.h2}</h2>
        <p class="mt-3 text-base text-n80">{m.subtitle}</p>
      </div>
      <a
        href="#cta"
        class="inline-flex h-[46px] shrink-0 items-center justify-center rounded-[var(--radius-btn)] border border-n95 bg-paper px-6 text-base transition-colors hover:border-n90 hover:bg-n97"
      >
        {cta}
      </a>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        m.cards.map((c) => (
          <article class="flex flex-col rounded-[12px] border border-n95 p-6 transition-colors hover:border-n90 hover:bg-n97">
            <span class="inline-flex h-12 w-12 items-center justify-center rounded-[10px] bg-ink text-[11px] font-medium text-paper">
              {c.platform}
            </span>
            <h3 class="mt-6 text-base font-medium">{c.title}</h3>
            <p class="mt-2 text-base text-n80">{c.desc}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>
