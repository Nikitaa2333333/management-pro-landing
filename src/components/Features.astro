---
import content from "../../content.json";
const f = content.features;
const strip = (s) => s.replace(/[«»]/g, "").trim();

const nav = [
  { label: "Проекты", icon: "grid" },
  { label: "Цепочки касаний", icon: "flow" },
  { label: "База ЛПР", icon: "users" },
  { label: "Встречи", icon: "calendar" },
  { label: "Интеграции", icon: "plug" },
];

const stats = [
  { label: "Ответы", value: "8–15%", delta: "+12%" },
  { label: "Цикл сделки", value: "35 дн", delta: "−61%" },
];
---

<section id="Методика" class="px-4 py-16 md:px-6 md:py-24">
  <div
    class="mx-auto grid max-w-[var(--spacing-container)] grid-cols-1 items-center gap-12 lg:grid-cols-2 lg:gap-16"
  >
    <!-- Левая колонка: текст -->
    <div>
      <span class="text-sm tracking-wide text-n80 uppercase">{f.label}</span>
      <h2 class="mt-6 text-[24px] leading-[30px] font-medium md:text-h2">{f.headline}</h2>
      <p class="mt-5 max-w-[520px] text-base text-n80">{f.text}</p>

      <a
        href="#cta"
        class="mt-8 inline-flex h-[46px] items-center justify-center rounded-[var(--radius-btn)] bg-ink px-6 text-base text-paper transition-colors hover:bg-ink-hover active:bg-ink-active"
      >
        {strip(f.cta)}
      </a>

      <ul class="mt-10 space-y-3">
        {
          f.bullets.map((b) => (
            <li class="flex gap-3 text-base">
              <span class="mt-[9px] inline-block h-[5px] w-[5px] shrink-0 rounded-full bg-ink" />
              <span>{b}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Правая колонка: тёмный mock-дашборд -->
    <div class="relative overflow-hidden rounded-[14px] bg-ink p-5 text-paper shadow-[0_20px_60px_-20px_rgba(0,0,0,0.5)]">
      <!-- Синий акцент-свечение -->
      <div
        class="pointer-events-none absolute -top-16 right-0 h-56 w-56 rounded-full opacity-50 blur-[60px]"
        style="background: radial-gradient(circle, rgba(37,99,235,0.7) 0%, transparent 70%);"
        aria-hidden="true"
      >
      </div>

      <!-- Точки окна -->
      <div class="relative mb-5 flex items-center gap-1.5">
        <span class="h-2.5 w-2.5 rounded-full bg-white/20"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-white/20"></span>
        <span class="h-2.5 w-2.5 rounded-full bg-white/20"></span>
      </div>

      <div class="relative grid grid-cols-[160px_1fr] gap-4">
        <!-- Сайдбар -->
        <aside>
          <div class="mb-4 flex items-center gap-2 text-[14px] font-medium">
            <span class="inline-flex h-5 w-5 items-center justify-center rounded bg-white text-ink">
              <svg width="11" height="11" viewBox="0 0 24 24" fill="none">
                <path d="M12 4v16M4 12h16" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" />
              </svg>
            </span>
            {content.brand}
          </div>

          <div class="mb-2 flex items-center justify-between rounded-md bg-white/[0.06] px-3 py-2 text-[12px] text-white/70 transition-colors hover:bg-white/10 hover:text-white">
            <span>Проектов</span>
            <span class="text-white">27</span>
          </div>
          <button
            class="mb-4 flex w-full cursor-pointer items-center justify-center gap-1.5 rounded-md bg-white py-2 text-[12px] font-medium text-ink transition-all hover:bg-white/90 hover:shadow-[0_0_20px_rgba(96,165,250,0.4)]"
          >
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none">
              <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" />
            </svg>
            Новая воронка
          </button>

          <nav class="space-y-1">
            {
              nav.map((item, idx) => (
                <div
                  class:list={[
                    "flex cursor-pointer items-center gap-2.5 rounded-md px-3 py-2 text-[13px] transition-colors hover:bg-white/10 hover:text-white",
                    idx === 0 ? "bg-white/10 text-white" : "text-white/50",
                  ]}
                >
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" class="shrink-0">
                    {item.icon === "grid" && (
                      <path d="M4 4h7v7H4zM13 4h7v7h-7zM4 13h7v7H4zM13 13h7v7h-7z" stroke="currentColor" stroke-width="1.5" />
                    )}
                    {item.icon === "flow" && (
                      <path d="M5 6h6M5 12h14M5 18h9M17 9l3 3-3 3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                    )}
                    {item.icon === "users" && (
                      <path d="M16 19c0-2.2-1.8-4-4-4s-4 1.8-4 4M12 11a3 3 0 100-6 3 3 0 000 6Z" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    )}
                    {item.icon === "calendar" && (
                      <path d="M4 6h16v14H4zM8 3v4M16 3v4M4 10h16" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    )}
                    {item.icon === "plug" && (
                      <path d="M9 3v5M15 3v5M7 8h10v3a5 5 0 01-10 0V8ZM12 16v5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
                    )}
                  </svg>
                  {item.label}
                </div>
              ))
            }
          </nav>
        </aside>

        <!-- Основная зона -->
        <div class="space-y-3">
          <!-- График -->
          <div class="group rounded-xl bg-white/[0.04] p-4 transition-all hover:bg-white/[0.07] hover:ring-1 hover:ring-[#2563EB]/40">
            <div class="flex items-start justify-between">
              <div>
                <div class="text-[13px] text-white/55">Назначено встреч</div>
                <div class="mt-1 text-[28px] leading-none font-medium">8–12 / мес</div>
              </div>
              <span class="rounded-full bg-[#2563EB]/20 px-2 py-1 text-[11px] font-medium text-[#60A5FA]">
                +47%
              </span>
            </div>

            <svg viewBox="0 0 320 120" class="mt-4 w-full" fill="none" preserveAspectRatio="none">
              <defs>
                <linearGradient id="area" x1="0" y1="0" x2="0" y2="1">
                  <stop offset="0%" stop-color="#2563EB" stop-opacity="0.45" />
                  <stop offset="100%" stop-color="#2563EB" stop-opacity="0" />
                </linearGradient>
              </defs>
              <path
                d="M0 95 C40 80 60 100 100 78 C140 56 170 70 210 48 C250 28 280 40 320 22 L320 120 L0 120 Z"
                fill="url(#area)"
              />
              <path
                d="M0 95 C40 80 60 100 100 78 C140 56 170 70 210 48 C250 28 280 40 320 22"
                stroke="#60A5FA"
                stroke-width="2.5"
                stroke-linecap="round"
                class="transition-[stroke-width] group-hover:[stroke-width:3.5]"
              />
              <circle cx="320" cy="22" r="9" fill="#2563EB" fill-opacity="0.25" class="animate-ping origin-center" style="transform-box: fill-box;" />
              <circle cx="320" cy="22" r="4" fill="#60A5FA" />
            </svg>

            <div class="mt-3 flex justify-between text-[11px] text-white/40">
              {["JAN", "FEB", "MAR", "APR", "MAY"].map((m) => <span>{m}</span>)}
            </div>
          </div>

          <!-- Мини-статы -->
          <div class="grid grid-cols-2 gap-3">
            {
              stats.map((s) => (
                <div class="cursor-default rounded-xl bg-white/[0.04] p-4 transition-all hover:bg-white/[0.07] hover:ring-1 hover:ring-[#2563EB]/40">
                  <div class="text-[12px] text-white/55">{s.label}</div>
                  <div class="mt-1 flex items-baseline gap-2">
                    <span class="text-[20px] font-medium">{s.value}</span>
                    <span class="text-[11px] text-[#60A5FA]">{s.delta}</span>
                  </div>
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
