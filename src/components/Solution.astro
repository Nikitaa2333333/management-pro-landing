---
import content from "../../content.json";
const s = content.solution;
const cards = content.value_cards;
---

<section id="Как работает" class="px-4 py-16 md:px-6 md:py-24">
  <div class="mx-auto max-w-[var(--spacing-container)]">
    <!-- Метка -->
    <span class="text-sm tracking-wide text-n80 uppercase">{s.label}</span>

    <!-- Двухтоновый заголовок: основная мысль чёрным, продолжение серым -->
    <h2 class="mt-6 max-w-[1000px] text-[24px] leading-[30px] font-medium md:text-h2">
      <span class="text-ink">{s.text[0]}</span>{" "}
      <span class="text-n80">{s.text[1]}</span>
    </h2>

    <!-- Три карточки ценности -->
    <div class="mt-16 grid grid-cols-1 gap-x-8 gap-y-12 border-t border-n95 pt-12 md:grid-cols-3">
      {
        cards.map((c, idx) => (
          <div>
            <div class="mb-6 text-ink" aria-hidden="true">
              {idx === 0 && (
                <svg width="56" height="56" viewBox="0 0 56 56" fill="currentColor">
                  {/* Восходящая линия тренда */}
                  <circle cx="4" cy="38" r="1.6" />
                  <circle cx="12" cy="30" r="1.6" />
                  <circle cx="20" cy="22" r="1.6" />
                  <circle cx="28" cy="14" r="1.6" />
                  <circle cx="36" cy="6" r="1.6" />
                  <circle cx="44" cy="6" r="1.6" />
                  <circle cx="36" cy="14" r="1.6" />

                  {/* Столбец 1 (высота 3, шаг 4) */}
                  <circle cx="12" cy="42" r="1.6" />
                  <circle cx="12" cy="46" r="1.6" />
                  <circle cx="12" cy="50" r="1.6" />

                  {/* Столбец 2 (высота 5, шаг 4) */}
                  <circle cx="20" cy="34" r="1.6" />
                  <circle cx="20" cy="38" r="1.6" />
                  <circle cx="20" cy="42" r="1.6" />
                  <circle cx="20" cy="46" r="1.6" />
                  <circle cx="20" cy="50" r="1.6" />

                  {/* Столбец 3 (высота 7, шаг 4) */}
                  <circle cx="28" cy="26" r="1.6" />
                  <circle cx="28" cy="30" r="1.6" />
                  <circle cx="28" cy="34" r="1.6" />
                  <circle cx="28" cy="38" r="1.6" />
                  <circle cx="28" cy="42" r="1.6" />
                  <circle cx="28" cy="46" r="1.6" />
                  <circle cx="28" cy="50" r="1.6" />

                  {/* Столбец 4 (высота 9, шаг 4) */}
                  <circle cx="36" cy="18" r="1.6" />
                  <circle cx="36" cy="22" r="1.6" />
                  <circle cx="36" cy="26" r="1.6" />
                  <circle cx="36" cy="30" r="1.6" />
                  <circle cx="36" cy="34" r="1.6" />
                  <circle cx="36" cy="38" r="1.6" />
                  <circle cx="36" cy="42" r="1.6" />
                  <circle cx="36" cy="46" r="1.6" />
                  <circle cx="36" cy="50" r="1.6" />
                </svg>
              )}
              {idx === 1 && (
                <svg width="56" height="56" viewBox="0 0 56 56" fill="currentColor">
                  {/* Квадрат-мишень */}
                  <circle cx="8" cy="8" r="1.6" /><circle cx="14" cy="8" r="1.6" /><circle cx="20" cy="8" r="1.6" /><circle cx="26" cy="8" r="1.6" /><circle cx="32" cy="8" r="1.6" /><circle cx="38" cy="8" r="1.6" /><circle cx="44" cy="8" r="1.6" /><circle cx="50" cy="8" r="1.6" />
                  <circle cx="8" cy="50" r="1.6" /><circle cx="14" cy="50" r="1.6" /><circle cx="20" cy="50" r="1.6" /><circle cx="26" cy="50" r="1.6" /><circle cx="32" cy="50" r="1.6" /><circle cx="38" cy="50" r="1.6" /><circle cx="44" cy="50" r="1.6" /><circle cx="50" cy="50" r="1.6" />
                  <circle cx="8" cy="14" r="1.6" /><circle cx="8" cy="20" r="1.6" /><circle cx="8" cy="26" r="1.6" /><circle cx="8" cy="32" r="1.6" /><circle cx="8" cy="38" r="1.6" /><circle cx="8" cy="44" r="1.6" />
                  <circle cx="50" cy="14" r="1.6" /><circle cx="50" cy="20" r="1.6" /><circle cx="50" cy="26" r="1.6" /><circle cx="50" cy="32" r="1.6" /><circle cx="50" cy="38" r="1.6" /><circle cx="50" cy="44" r="1.6" />
                  <circle cx="29" cy="29" r="1.6" />
                  <circle cx="29" cy="23" r="1.6" /><circle cx="29" cy="17" r="1.6" />
                  <circle cx="29" cy="35" r="1.6" /><circle cx="29" cy="41" r="1.6" />
                  <circle cx="23" cy="29" r="1.6" /><circle cx="17" cy="29" r="1.6" />
                  <circle cx="35" cy="29" r="1.6" /><circle cx="41" cy="29" r="1.6" />
                </svg>
              )}
              {idx === 2 && (
                <svg width="56" height="56" viewBox="0 0 56 56" fill="currentColor">
                  {/* Команда/Люди */}
                  <circle cx="28" cy="14" r="1.6" />
                  <circle cx="22" cy="20" r="1.6" /><circle cx="28" cy="20" r="1.6" /><circle cx="34" cy="20" r="1.6" />
                  <circle cx="22" cy="26" r="1.6" /><circle cx="28" cy="26" r="1.6" /><circle cx="34" cy="26" r="1.6" />
                  <circle cx="28" cy="32" r="1.6" />
                  <circle cx="14" cy="26" r="1.6" />
                  <circle cx="8" cy="32" r="1.6" /><circle cx="14" cy="32" r="1.6" /><circle cx="20" cy="32" r="1.6" />
                  <circle cx="8" cy="38" r="1.6" /><circle cx="14" cy="38" r="1.6" /><circle cx="20" cy="38" r="1.6" />
                  <circle cx="14" cy="44" r="1.6" />
                  <circle cx="42" cy="26" r="1.6" />
                  <circle cx="36" cy="32" r="1.6" /><circle cx="42" cy="32" r="1.6" /><circle cx="48" cy="32" r="1.6" />
                  <circle cx="36" cy="38" r="1.6" /><circle cx="42" cy="38" r="1.6" /><circle cx="48" cy="38" r="1.6" />
                  <circle cx="42" cy="44" r="1.6" />
                </svg>
              )}
            </div>
            <h3 class="text-base font-medium text-ink">{c.title}</h3>
            <p class="mt-2 text-base text-n80">{c.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
