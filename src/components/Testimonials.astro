---
import content from "../../content.json";
const items = content.testimonials;
---

<section id="Кейсы" class="px-4 py-16 md:px-6 md:py-24">
  <div class="mx-auto max-w-[var(--spacing-container)]">
    <h2 class="text-center text-[24px] leading-[30px] font-medium md:text-h2">
      Что клиенты говорят о нас
    </h2>

    <div class="mt-12 space-y-8">
      {
        items.map((it) => {
          const quote = it.quote.replace(/[«»]/g, "").trim();
          return (
            <figure class="mx-auto max-w-[860px] rounded-[12px] border border-n95 bg-paper px-6 py-12 text-center md:px-12">
              <span class="inline-flex items-center gap-2 rounded-[var(--radius-btn)] bg-ink px-4 py-2 text-sm text-paper">
                <span class="inline-block h-1.5 w-1.5 rounded-full bg-white/70" />
                {it.badge}
              </span>
              <blockquote class="mx-auto mt-8 max-w-[680px] text-[22px] leading-[30px] font-medium">
                «{quote}»
              </blockquote>
              <figcaption class="mt-8 text-base text-n80">{it.author}</figcaption>
            </figure>
          );
        })
      }
    </div>
  </div>
</section>
