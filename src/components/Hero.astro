---
import content from "../../content.json";
const h = content.hero;
const strip = (s) => s.replace(/[«»]/g, "").trim();

const cards = [
  { role: "Директор, оптовая компания", status: "Проявил интерес", icon: "shuffle" },
  { role: "Co-founder, B2B-сервис", status: "Готов к разговору", icon: "chat" },
];
---

<section class="px-4 pt-20 pb-16 md:px-6 md:pt-28 md:pb-20">
  <!-- Заголовочный блок -->
  <div class="mx-auto flex max-w-[760px] flex-col items-center text-center">
    <!-- Метка -->
    <span class="mb-6 text-sm tracking-wide text-n80 uppercase">{h.label}</span>

    <!-- H1 -->
    <h1 class="text-[28px] leading-[32px] font-medium text-balance md:text-display">
      {h.h1}
    </h1>

    <!-- Подзаголовок -->
    <p class="mt-5 max-w-[620px] text-base text-n80">
      {h.subtitle}
    </p>

    <!-- CTA -->
    <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row">
      <a
        href="#cta"
        class="flex h-[46px] items-center justify-center rounded-[var(--radius-btn)] bg-ink px-6 text-base text-paper transition-colors hover:bg-ink-hover active:bg-ink-active"
      >
        {strip(h.cta_primary)}
      </a>
      <a
        href="#cases"
        class="flex h-[46px] items-center justify-center rounded-[var(--radius-btn)] border border-n95 bg-paper px-6 text-base text-ink transition-colors hover:border-n90 hover:bg-n97"
      >
        {strip(h.cta_secondary)}
      </a>
    </div>
  </div>

  <!-- Визуальный блок -->
  <div class="mx-auto mt-14 grid w-full max-w-[var(--spacing-container)] grid-cols-1 gap-5 md:grid-cols-2">
    <!-- ЛЕВО: живой интерфейс воронки лидов -->
    <div
      class="relative flex aspect-[4/5] items-center overflow-hidden rounded-[12px] bg-black p-5 md:aspect-[4/5] md:p-7"
    >
      <!-- Синие сферы со светящимся ободком -->
      <div
        class="pointer-events-none absolute top-[-38%] left-1/2 aspect-square w-[118%] -translate-x-1/2 rounded-full opacity-95 blur-[28px]"
        style="background: radial-gradient(circle, transparent 43%, rgba(96,165,250,0.45) 47%, rgba(37,99,235,0.95) 51%, rgba(37,99,235,0.2) 56%, transparent 62%);"
        aria-hidden="true"
      >
      </div>
      <div
        class="pointer-events-none absolute bottom-[-38%] left-1/2 aspect-square w-[118%] -translate-x-1/2 rounded-full opacity-95 blur-[28px]"
        style="background: radial-gradient(circle, transparent 43%, rgba(96,165,250,0.45) 47%, rgba(37,99,235,0.95) 51%, rgba(37,99,235,0.2) 56%, transparent 62%);"
        aria-hidden="true"
      >
      </div>

      <!-- Карточки -->
      <div class="relative z-10 flex w-full flex-col gap-3">
        {
          cards.map((c) => (
            <div class="glass p-4">
              <div class="flex items-center justify-between">
                <span class="text-[15px] text-white/85">{c.role}</span>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="text-white/35">
                  <rect x="9" y="9" width="11" height="11" rx="2" stroke="currentColor" stroke-width="1.6" />
                  <path d="M5 15V5a2 2 0 0 1 2-2h10" stroke="currentColor" stroke-width="1.6" />
                </svg>
              </div>
              <div class="my-3.5 h-px w-full bg-white/15" />
              <div class="flex items-center gap-3">
                <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-black/40 text-white">
                  {c.icon === "shuffle" ? (
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                      <path d="M16 3h5v5M21 3l-7 7M8 21H3v-5M3 21l7-7M21 16v5h-5M14 14l7 7M3 3l6 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  ) : (
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
                      <path d="M21 11.5a8.5 8.5 0 0 1-12.3 7.6L3 21l1.9-5.7A8.5 8.5 0 1 1 21 11.5Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round" />
                    </svg>
                  )}
                </span>
                <span class="text-[15px] text-white">{c.status}</span>
              </div>
            </div>
          ))
        }

        <!-- Кнопки воронки -->
        <div class="flex gap-3">
          {
            ["Новый лид", "Новая воронка"].map((b) => (
              <span class="glass glass--pill flex items-center gap-2 px-4 py-2.5 text-[14px] text-white/90">
                {b}
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
                  <path d="M12 5v14M5 12h14" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                </svg>
              </span>
            ))
          }
        </div>
      </div>
    </div>

    <!-- ПРАВО: место под фото -->
    <div class="relative aspect-[4/5] overflow-hidden rounded-[12px] bg-n95">
      <img
        src={`${import.meta.env.BASE_URL}founder_editorial_portrait.png`}
        alt="Николай Григорян, основатель МЕНЕДЖМЕНТ.PRO"
        class="h-full w-full object-cover"
        loading="eager"
      />
    </div>
  </div>
</section>

<style>
  /* Лёгкий оптимизированный glassmorphism (без SVG-фильтров) */
  .glass {
    position: relative;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.07);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.14);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.18);
    transition: background 0.2s ease, border-color 0.2s ease;
  }
  .glass--pill {
    display: inline-flex;
    border-radius: 12px;
  }
  .glass:hover {
    background: rgba(255, 255, 255, 0.11);
    border-color: rgba(96, 165, 250, 0.5);
  }
</style>
