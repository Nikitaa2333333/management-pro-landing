---
import content from "../../content.json";
const c = content.final_cta;
const cta = c.cta.replace(/[«»]/g, "").trim();
---

<section id="cta" class="px-4 py-16 md:px-6 md:py-24">
  <div
    class="relative mx-auto max-w-[var(--spacing-container)] overflow-hidden rounded-[12px] bg-ink px-6 py-24 text-center text-paper md:px-12 md:py-32"
  >
    <!-- Светящийся обод сферы -->
    <div
      class="cta-ring pointer-events-none absolute top-1/2 left-1/2 aspect-square w-[140%] max-w-[1000px] rounded-full blur-[40px]"
      style="background: radial-gradient(circle, transparent 42%, rgba(96,165,250,0.55) 47%, rgba(37,99,235,0.95) 50%, rgba(37,99,235,0.25) 54%, transparent 60%);"
      aria-hidden="true"
    >
    </div>
    <!-- Мягкое внутреннее свечение под ободом -->
    <div
      class="cta-glow pointer-events-none absolute top-1/2 left-1/2 aspect-square w-[80%] max-w-[600px] rounded-full blur-[80px]"
      style="background: radial-gradient(circle, rgba(37,99,235,0.6) 0%, transparent 70%);"
      aria-hidden="true"
    >
    </div>

    <!-- Контент -->
    <div class="relative z-10">
      <span class="text-sm tracking-wide text-white/55 uppercase">{c.label}</span>
      <h2 class="mx-auto mt-6 max-w-[720px] text-[26px] leading-[32px] font-medium md:text-display">
        {c.headline}
      </h2>
      <p class="mx-auto mt-5 max-w-[640px] text-base text-white/70">{c.text}</p>

      <a
        href="#Контакты"
        class="mt-9 inline-flex h-[46px] items-center justify-center rounded-[var(--radius-btn)] bg-paper px-6 text-base text-ink transition-opacity hover:opacity-90"
      >
        {cta}
      </a>

      <p class="mt-5 text-sm text-white/45">{c.note}</p>
    </div>
  </div>
</section>

<style>
  /* «Дыхание» свечения — плавный fade + лёгкое масштабирование */
  .cta-ring {
    opacity: 0.9;
    transform: translate(-50%, -50%);
    animation: cta-breathe-ring 7s ease-in-out infinite;
  }
  .cta-glow {
    opacity: 0.5;
    transform: translate(-50%, -50%);
    animation: cta-breathe-glow 5.5s ease-in-out infinite;
  }

  @keyframes cta-breathe-ring {
    0%,
    100% {
      opacity: 0.55;
      transform: translate(-50%, -50%) scale(0.97);
    }
    50% {
      opacity: 0.95;
      transform: translate(-50%, -50%) scale(1.05);
    }
  }
  @keyframes cta-breathe-glow {
    0%,
    100% {
      opacity: 0.3;
      transform: translate(-50%, -50%) scale(1);
    }
    50% {
      opacity: 0.65;
      transform: translate(-50%, -50%) scale(1.15);
    }
  }

  /* Уважаем системную настройку «меньше движения» */
  @media (prefers-reduced-motion: reduce) {
    .cta-ring,
    .cta-glow {
      animation: none;
    }
  }
</style>
