---
import content from "../../content.json";
const t = content.trust;
const stat = t.stat.replace(/[«»]/g, "").trim();
---

<section class="px-4 py-16 md:px-6 md:py-20">
  <div class="mx-auto max-w-[var(--spacing-container)] text-center">
    <h2 class="mx-auto max-w-[680px] text-[24px] leading-[30px] font-medium md:text-h2">
      {t.heading}
    </h2>

    <!-- Логотипы клиентов (текстом, как в исходнике) -->
    <div class="mt-10 flex flex-wrap items-center justify-center gap-x-10 gap-y-4">
      {
        t.logos.map((logo) => (
          <span class="text-[18px] font-medium text-ink/80">{logo}</span>
        ))
      }
    </div>

    <!-- Строка с цифрами результата -->
    <p class="mx-auto mt-10 max-w-[760px] text-base text-n80">{stat}</p>
  </div>
</section>
